<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JARVIS — Monsef OS</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#e8e4db;--card:#f5f2ec;--white:#fdfcf9;
  --border:rgba(80,65,40,0.1);--border-md:rgba(80,65,40,0.18);
  --text:#1a1814;--muted:#8a8278;--faint:#b8b2a8;
  --accent:#2d6a4a;--accent-bg:#e8f2ec;
  --yellow:#d4a017;--yellow-bg:#fdf5dc;
  --red:#c0392b;--red-bg:#fbeae8;
  --font:'Geist',-apple-system,sans-serif;--mono:'Geist Mono',monospace;
  --r:100px;--rc:20px;--rs:12px;
}
body{background:var(--bg);font-family:var(--font);color:var(--text);height:100vh;overflow:hidden;display:flex;flex-direction:column;}
.topnav{display:flex;align-items:center;padding:12px 24px;gap:6px;background:var(--bg);flex-shrink:0;}
.app-name{font-size:17px;font-weight:600;color:var(--text);margin-right:8px;letter-spacing:-0.03em;}
.nav-pills{display:flex;gap:4px;flex:1;flex-wrap:wrap;}
.pill{display:flex;align-items:center;gap:6px;padding:7px 16px;border-radius:var(--r);font-size:13px;font-weight:400;color:var(--muted);cursor:pointer;transition:all 0.18s;background:transparent;border:none;font-family:var(--font);}
.pill:hover{background:var(--card);color:var(--text);}
.pill.active{background:var(--white);color:var(--text);font-weight:500;box-shadow:0 1px 4px rgba(0,0,0,0.07);}
.topnav-right{display:flex;align-items:center;gap:8px;margin-left:auto;}
.date-chip{padding:6px 12px;border-radius:var(--r);background:var(--card);font-size:11px;font-family:var(--mono);color:var(--muted);}
.avatar{width:32px;height:32px;border-radius:50%;background:var(--text);color:var(--card);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;cursor:pointer;}
.fs-btn{width:32px;height:32px;border-radius:10px;background:var(--card);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--muted);transition:all 0.15s;}
.fs-btn:hover{background:var(--white);color:var(--text);}
.body{flex:1;overflow-y:auto;padding:0 24px 28px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.page{display:none;}
.page.active{display:block;}
.card{background:var(--card);border-radius:var(--rc);padding:20px;}
.card-w{background:var(--white);border-radius:var(--rc);padding:20px;}

/* DASHBOARD */
.dash-name{font-size:28px;font-weight:300;letter-spacing:-0.04em;line-height:1.1;margin-bottom:16px;}
.dash-name strong{font-weight:600;}
.metrics{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:14px;}
.m-card{background:var(--card);border-radius:var(--rc);padding:14px 16px;}
.m-lbl{font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--faint);font-family:var(--mono);margin-bottom:5px;}
.m-val{font-size:24px;font-weight:500;letter-spacing:-0.03em;line-height:1;}
.m-val .u{font-size:12px;font-weight:400;color:var(--muted);margin-left:2px;}
.m-sub{font-size:11px;color:var(--muted);margin-top:3px;}
.phase-row{display:flex;align-items:center;gap:14px;background:var(--card);border-radius:var(--rc);padding:14px 20px;margin-bottom:14px;}
.pdot{width:10px;height:10px;border-radius:50%;background:var(--yellow);flex-shrink:0;}
.p-info{flex:1;}
.p-tag{display:inline-block;padding:2px 9px;border-radius:var(--r);font-size:10px;font-family:var(--mono);background:var(--yellow-bg);color:#7a5c00;margin-bottom:2px;}
.p-title{font-size:13px;font-weight:500;}
.p-dates{font-size:11px;color:var(--muted);margin-top:1px;}
.p-pct{font-size:26px;font-weight:500;font-family:var(--mono);letter-spacing:-0.04em;}
.p-bar{width:110px;height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:4px;}
.p-fill{height:100%;background:var(--yellow);border-radius:2px;}
.tri{display:grid;grid-template-columns:1.3fr 1fr 1fr;gap:12px;margin-bottom:14px;}
.p-lbl{font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--faint);font-family:var(--mono);margin-bottom:12px;}
.h-mini{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);}
.h-mini:last-child{border-bottom:none;}
.h-n{font-size:13px;}.h-s{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:1px;}
.dots{display:flex;gap:3px;}
.dot{width:9px;height:9px;border-radius:50%;background:var(--bg);border:1.5px solid var(--border);cursor:pointer;transition:all 0.12s;}
.dot.on{background:var(--text);border-color:var(--text);}
.okr-m{margin-bottom:10px;}.okr-m:last-child{margin-bottom:0;}
.okr-mh{display:flex;justify-content:space-between;margin-bottom:4px;}
.okr-mn{font-size:12px;color:var(--text);flex:1;padding-right:8px;line-height:1.4;}
.okr-mp{font-size:12px;font-family:var(--mono);color:var(--muted);}
.bar{height:4px;background:var(--bg);border-radius:2px;overflow:hidden;}
.bf{height:100%;background:var(--text);border-radius:2px;transition:width 0.5s;}
.note-box{background:var(--yellow-bg);border-radius:10px;padding:12px 14px;font-size:13px;line-height:1.65;font-style:italic;}
.note-d{font-size:10px;font-family:var(--mono);color:var(--muted);font-style:normal;margin-bottom:5px;}
.dash-chart-wrap{background:var(--card);border-radius:var(--rc);padding:16px;}

/* HABITS */
.habits-toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.h-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.h-row:last-child{border-bottom:none;}
.h-ico{width:34px;height:34px;border-radius:9px;background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.h-col{flex:1;}.h-nm{font-size:14px;font-weight:500;}.h-dc{font-size:11px;color:var(--muted);margin-top:1px;}
.dcells{display:flex;gap:3px;}
.dc{width:30px;height:30px;border-radius:7px;background:var(--bg);border:1.5px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:11px;color:transparent;transition:all 0.12s;}
.dc:hover{border-color:var(--muted);}
.dc.on{background:var(--text);color:var(--white);border-color:var(--text);}
.dc.today{border-color:var(--accent);border-width:2px;}
.streak{padding:3px 9px;border-radius:var(--r);font-size:11px;font-family:var(--mono);background:var(--bg);color:var(--muted);white-space:nowrap;}
.h-actions{display:flex;gap:4px;}
.h-act-btn{width:26px;height:26px;border-radius:6px;border:none;background:transparent;cursor:pointer;color:var(--faint);font-size:13px;display:flex;align-items:center;justify-content:center;transition:all 0.12s;}
.h-act-btn:hover{background:var(--bg);color:var(--text);}
.habit-charts-section{margin-top:20px;}
.habit-charts-global{background:var(--card);border-radius:var(--rc);padding:16px;margin-bottom:14px;}
.habit-charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.hc-item{background:var(--card);border-radius:var(--rc);padding:14px 16px;}
.hc-lbl{font-size:11px;font-weight:500;color:var(--text);margin-bottom:8px;}

/* OKRs */
.okr-blk{background:var(--card);border-radius:var(--rc);padding:20px;margin-bottom:10px;}
.okr-blk:last-child{margin-bottom:0;}
.okr-top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:10px;}
.okr-obj-wrap{flex:1;}
.okr-obj{font-size:15px;font-weight:500;letter-spacing:-0.02em;line-height:1.3;}
.okr-phase-tag{display:inline-block;padding:2px 8px;border-radius:var(--r);font-size:10px;font-family:var(--mono);background:var(--bg);color:var(--muted);margin-top:4px;}
.okr-right{display:flex;align-items:center;gap:8px;flex-shrink:0;}
.okr-pct{font-size:28px;font-weight:500;font-family:var(--mono);letter-spacing:-0.04em;}
.okr-bar{height:5px;background:var(--bg);border-radius:3px;overflow:hidden;margin-bottom:14px;}
.okr-bf{height:100%;background:var(--text);border-radius:3px;transition:width 0.5s;}
.kr{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);cursor:pointer;}
.kr:last-child{border-bottom:none;}
.kr-box{width:16px;height:16px;border-radius:4px;border:1.5px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all 0.12s;}
.kr.done .kr-box{background:var(--text);border-color:var(--text);}
.kr.done .kr-box::after{content:'✓';font-size:9px;color:var(--white);}
.kr-t{font-size:13px;flex:1;}.kr.done .kr-t{text-decoration:line-through;color:var(--muted);}
.kr-actions{display:flex;gap:4px;flex-shrink:0;}
.okr-add-wrap{margin-top:14px;}
.okr-add-btn{display:flex;align-items:center;gap:8px;padding:10px 16px;border-radius:var(--rc);border:2px dashed var(--border-md);background:transparent;color:var(--muted);font-family:var(--font);font-size:13px;cursor:pointer;width:100%;justify-content:center;transition:all 0.15s;}
.okr-add-btn:hover{background:var(--card);color:var(--text);border-color:var(--text);}

/* MIND */
.mind-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;}
.chip{padding:7px 16px;border-radius:var(--r);font-size:12px;background:var(--card);color:var(--muted);cursor:pointer;transition:all 0.15s;border:none;font-family:var(--font);}
.chip:hover{background:var(--white);color:var(--text);}
.mind-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;height:calc(100vh - 230px);}
.chat-crd{background:var(--card);border-radius:var(--rc);display:flex;flex-direction:column;overflow:hidden;}
.chat-hd{display:flex;align-items:center;gap:8px;padding:12px 16px;border-bottom:1px solid var(--border);}
.chat-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);}
.chat-lbl{font-size:12px;font-weight:500;}
.chat-msgs{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:8px;scrollbar-width:thin;}
.cmsg{max-width:90%;padding:9px 13px;border-radius:12px;font-size:13px;line-height:1.6;animation:fu 0.2s ease;}
@keyframes fu{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.cmsg.user{background:var(--text);color:var(--white);align-self:flex-end;border-bottom-right-radius:3px;}
.cmsg.ai{background:var(--white);color:var(--text);align-self:flex-start;border-bottom-left-radius:3px;}
.cmsg.typing{background:var(--white);color:var(--faint);align-self:flex-start;font-style:italic;font-size:12px;}
.chat-ft{padding:10px;border-top:1px solid var(--border);display:flex;gap:7px;}
.chat-in{flex:1;background:var(--white);border:none;border-radius:var(--r);padding:9px 14px;font-family:var(--font);font-size:13px;color:var(--text);outline:none;resize:none;min-height:38px;max-height:80px;}
.chat-in::placeholder{color:var(--faint);}
.chat-send{width:38px;height:38px;border-radius:50%;background:var(--text);border:none;color:var(--white);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.chat-send:hover{opacity:0.8;}
.write-crd{background:var(--card);border-radius:var(--rc);display:flex;flex-direction:column;overflow:hidden;}
.write-hd{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.write-lbl{font-size:12px;font-weight:500;}.wc{font-size:11px;font-family:var(--mono);color:var(--faint);}
.write-ta{flex:1;border:none;background:transparent;padding:16px;font-family:var(--font);font-size:13px;color:var(--text);resize:none;outline:none;line-height:1.8;min-height:0;}
.write-ta::placeholder{color:var(--faint);font-style:italic;}
.write-ft{padding:9px 16px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:8px;}
.mood-row{display:flex;align-items:center;gap:7px;}
.mood-lbl{font-size:11px;color:var(--muted);font-family:var(--mono);}
.mood-btns{display:flex;gap:3px;}
.mood-btn{width:26px;height:26px;border-radius:7px;border:1.5px solid var(--border);background:var(--bg);font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.12s;color:var(--muted);font-family:var(--mono);font-weight:500;}
.mood-btn.sel{background:var(--text);color:var(--white);border-color:var(--text);}

/* HISTORY */
.hist-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.hist-title{font-size:19px;font-weight:500;letter-spacing:-0.02em;}
.hist-sub{font-size:13px;color:var(--muted);margin-top:2px;}
.mood-strip{display:flex;gap:7px;margin-bottom:16px;flex-wrap:wrap;}
.mood-day-pill{display:flex;align-items:center;gap:5px;background:var(--card);border-radius:var(--r);padding:5px 12px;}
.mood-day-emoji{font-size:14px;}.mood-day-score{font-family:var(--mono);font-size:11px;color:var(--text);font-weight:500;}
.mood-day-label{font-family:var(--mono);font-size:10px;color:var(--muted);}
.bilan-card{background:var(--yellow-bg);border-radius:var(--rc);padding:16px 20px;margin-bottom:16px;border-left:3px solid var(--yellow);}
.bilan-lbl{font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--yellow);font-family:var(--mono);margin-bottom:6px;}
.bilan-text{font-size:14px;line-height:1.75;color:var(--text);}
.entry-card{background:var(--card);border-radius:var(--rc);padding:18px;margin-bottom:10px;}
.entry-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;gap:10px;}
.entry-date-big{font-size:13px;font-weight:500;}.entry-date-sub{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:1px;}
.entry-mood-badge{display:flex;align-items:center;gap:5px;background:var(--white);border-radius:var(--r);padding:5px 12px;flex-shrink:0;}
.entry-mood-emoji{font-size:15px;}.entry-mood-score{font-family:var(--mono);font-size:12px;font-weight:500;color:var(--text);}
.entry-body{font-size:13px;line-height:1.75;color:var(--text);margin-bottom:12px;white-space:pre-wrap;}
.entry-summary{background:var(--white);border-radius:var(--rs);padding:10px 14px;font-size:12px;line-height:1.65;color:var(--muted);border-left:2px solid var(--accent);font-style:italic;}
.entry-summary-lbl{font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);font-family:var(--mono);margin-bottom:4px;font-style:normal;}

/* CALENDAR */
.gcal-wrap{display:flex;flex-direction:column;height:calc(100vh - 110px);}
.gcal-toolbar{display:flex;align-items:center;gap:10px;padding:0 0 12px;flex-shrink:0;}
.gcal-today-btn{padding:7px 16px;border-radius:var(--r);border:1.5px solid var(--border-md);background:var(--white);font-family:var(--font);font-size:13px;cursor:pointer;color:var(--text);}
.gcal-today-btn:hover{background:var(--card);}
.gcal-nav-btn{width:30px;height:30px;border-radius:50%;border:none;background:transparent;cursor:pointer;font-size:16px;color:var(--muted);display:flex;align-items:center;justify-content:center;}
.gcal-nav-btn:hover{background:var(--card);}
.gcal-period{font-size:18px;font-weight:500;letter-spacing:-0.02em;flex:1;}
.gcal-status-pill{display:flex;align-items:center;gap:7px;background:var(--card);border-radius:var(--r);padding:6px 14px;}
.gcal-dot{width:7px;height:7px;border-radius:50%;background:var(--faint);}
.gcal-dot.on{background:#4caf50;}
.gcal-lbl{font-size:11px;font-family:var(--mono);color:var(--muted);}
.week-grid{flex:1;display:grid;grid-template-columns:48px repeat(7,1fr);overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.wh-corner{background:var(--bg);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:10;}
.wh-day{background:var(--bg);border-bottom:1px solid var(--border);border-left:1px solid var(--border);padding:8px 6px;text-align:center;position:sticky;top:0;z-index:10;cursor:pointer;}
.wh-day-name{font-size:11px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:0.06em;}
.wh-day-num{font-size:22px;font-weight:300;letter-spacing:-0.03em;margin-top:2px;}
.wh-day.is-today .wh-day-num{background:var(--accent);color:white;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:2px auto 0;}
.time-col{display:flex;flex-direction:column;}
.time-slot{height:48px;display:flex;align-items:flex-start;justify-content:flex-end;padding:2px 6px 0 0;font-size:10px;font-family:var(--mono);color:var(--faint);flex-shrink:0;}
.day-col{border-left:1px solid var(--border);position:relative;display:flex;flex-direction:column;}
.day-hour{height:48px;border-bottom:1px solid rgba(80,65,40,0.06);flex-shrink:0;cursor:pointer;transition:background 0.1s;}
.day-hour:hover{background:rgba(45,106,74,0.04);}
.gcal-event{position:absolute;left:2px;right:2px;border-radius:6px;padding:2px 6px;font-size:11px;font-weight:500;cursor:pointer;overflow:hidden;z-index:5;transition:opacity 0.15s;}
.gcal-event:hover{opacity:0.85;}
.gcal-event.gcal-src{background:#1a73e8;color:white;}
.gcal-event.local-src{background:var(--accent);color:white;}

/* MODALS */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.3);z-index:99;}
.modal-overlay.open{display:block;}
.modal{display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--white);border-radius:var(--rc);padding:24px;width:380px;box-shadow:0 8px 32px rgba(0,0,0,0.15);z-index:100;}
.modal.open{display:block;}
.modal-title{font-size:16px;font-weight:500;margin-bottom:16px;}
.modal-input{width:100%;border:1.5px solid var(--border-md);border-radius:10px;padding:10px 14px;font-family:var(--font);font-size:13px;color:var(--text);outline:none;margin-bottom:10px;background:var(--bg);}
.modal-input:focus{border-color:var(--accent);}
.modal-row{display:flex;gap:8px;margin-bottom:10px;}
.modal-row .modal-input{margin-bottom:0;}
.modal-btns{display:flex;justify-content:flex-end;gap:8px;margin-top:6px;}

/* FOCUS */
.focus-page{position:relative;width:100%;height:calc(100vh - 110px);overflow:hidden;border-radius:var(--rc);background:#000;}
.focus-video{position:absolute;inset:0;width:100%;height:100%;border:none;}
.focus-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.3);}
.focus-ui{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;color:white;pointer-events:none;}
.focus-clock{font-family:var(--mono);font-size:64px;font-weight:300;letter-spacing:0.08em;line-height:1;text-shadow:0 2px 20px rgba(0,0,0,0.6);}
.focus-timer{font-family:var(--mono);font-size:40px;font-weight:300;letter-spacing:0.06em;margin-top:16px;color:rgba(255,255,255,0.85);}
.focus-controls{display:flex;gap:12px;justify-content:center;margin-top:20px;pointer-events:all;}
.focus-btn{padding:10px 22px;border-radius:var(--r);border:2px solid rgba(255,255,255,0.4);background:rgba(255,255,255,0.12);color:white;font-family:var(--font);font-size:13px;cursor:pointer;transition:all 0.15s;backdrop-filter:blur(4px);}
.focus-btn:hover{background:rgba(255,255,255,0.22);border-color:rgba(255,255,255,0.8);}

/* fullscreen focus */
:fullscreen .focus-page,:fullscreen .page-focus-wrap{border-radius:0;height:100vh;width:100vw;}
:fullscreen .topnav,:fullscreen .body>:not(#page-focus){display:none;}

/* BTN */
.btn{padding:7px 16px;border-radius:var(--r);font-size:13px;font-family:var(--font);cursor:pointer;transition:all 0.15s;border:none;}
.btn-g{background:transparent;color:var(--muted);border:1.5px solid var(--border-md);}
.btn-g:hover{background:var(--bg);color:var(--text);}
.btn-s{background:var(--text);color:var(--card);}
.btn-s:hover{opacity:0.85;}
.btn-red{background:transparent;color:var(--red);border:1.5px solid rgba(192,57,43,0.25);font-size:12px;padding:5px 10px;}
.btn-red:hover{background:var(--red-bg);}
